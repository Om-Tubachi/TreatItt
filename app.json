{
  "expo": {
    "name": "TreatIt",
    "slug": "TreatIt",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "inventoryapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.anonymous.TreatIt"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "@react-native-google-signin/google-signin",
      "expo-splash-screen",
      "expo-sqlite",
      "expo-font",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}