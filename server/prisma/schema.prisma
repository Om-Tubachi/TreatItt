/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model frp {
  id               String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  composition_id   String?            @db.Uuid
  category_id      String?            @db.Uuid
  grade_id         String?            @db.Uuid
  resin_id         String?            @db.Uuid
  description      String?
  collector_types  collector_types[]
  category         category?          @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  composition      composition?       @relation(fields: [composition_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  grade            grade?             @relation(fields: [grade_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  resin            resin?             @relation(fields: [resin_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  frp_requirements frp_requirements[]
  frp_wastes       frp_wastes[]
  products         products[]
  treatments       treatments[]

  @@unique([composition_id, category_id, grade_id, resin_id])
}

