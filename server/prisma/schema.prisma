/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model lookup_entries {
  id               String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  entity_type      String          @db.VarChar
  entity_id        String          @db.Uuid
  u_id             String?         @db.Uuid
  frp_id           String?         @db.Uuid
  composition_id   String?         @db.Uuid
  category_id      String?         @db.Uuid
  grade_id         String?         @db.Uuid
  resin_id         String?         @db.Uuid
  form_template_id String?         @db.Uuid
  extra_filters    Json?           @default("{}")
  price            Decimal?        @db.Decimal
  status           String?         @db.VarChar
  latitude         Decimal?        @db.Decimal
  longitude        Decimal?        @db.Decimal
  createdat        DateTime?       @default(now()) @db.Timestamp(6)
  updatedat        DateTime?       @default(now()) @db.Timestamp(6)
  form_templates   form_templates? @relation(fields: [form_template_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([entity_type, entity_id])
  @@index([category_id], map: "idx_lookup_category")
  @@index([composition_id], map: "idx_lookup_composition")
  @@index([entity_type, form_template_id], map: "idx_lookup_entity_form")
  @@index([extra_filters(ops: JsonbPathOps)], map: "idx_lookup_gin", type: Gin)
}
